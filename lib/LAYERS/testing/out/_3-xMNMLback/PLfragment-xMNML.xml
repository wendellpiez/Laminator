   <end off="612" ext="66" gi="phr" rID="r39_phr"/>
   <text off="612" ext="1" cf="r01_excerpt r03_s r37_np r40_l"> </text>
   <start off="613" ext="58" gi="phr" rID="r41_phr"/>
   <text off="613" ext="16" cf="r01_excerpt r03_s r37_np r40_l r41_phr">while it pursues</text>
   <end off="629" ext="40" gi="l" rID="r40_l"/>
   <text off="629" ext="1" cf="r01_excerpt r03_s r37_np r41_phr">
</text>
   <start off="630" ext="41" gi="np" id="7" rID="r43_np"/>
   <start off="630" ext="41" gi="l" rID="r42_l">
      <annotation gi="n">Bk.1.16</annotation>
   </start>
