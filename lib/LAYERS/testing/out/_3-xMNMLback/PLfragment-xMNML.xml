   <end off="699" ext="9" gi="phr" rID="r48_phr"/>
   <text off="699" ext="1" cf="r01_excerpt r44_l r45_s r47_np"> </text>
   <start off="700" ext="63" gi="phr" rID="r49_phr"/>
   <text off="700" ext="16" cf="r01_excerpt r44_l r45_s r47_np r49_phr">that dost prefer</text>
   <end off="716" ext="44" gi="l" rID="r44_l"/>
   <text off="716" ext="1" cf="r01_excerpt r45_s r47_np r49_phr">
</text>
   <start off="717" ext="46" gi="l" rID="r50_l">
      <annotation gi="n">Bk.1.18</annotation>
   </start>
