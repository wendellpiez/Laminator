   <end off="506" ext="35" gi="l" rID="r34_l"/>
   <text off="506" ext="1" cf="r01_excerpt r03_s r35_phr">
</text>
   <start off="507" ext="38" gi="l" rID="r36_l">
      <annotation gi="n">Bk.1.13</annotation>
   </start>
   <text off="507" ext="18" cf="r01_excerpt r03_s r35_phr r36_l">Invoke thy aid to </text>
   <start off="525" ext="146" gi="np" id="6" rID="r37_np"/>
   <text off="525" ext="20" cf="r01_excerpt r03_s r35_phr r36_l r37_np">my adventurous song,</text>
   <end off="545" ext="47" gi="phr" rID="r35_phr"/>
   <end off="545" ext="38" gi="l" rID="r36_l"/>
   <text off="545" ext="1" cf="r01_excerpt r03_s r37_np">
</text>
   <start off="546" ext="42" gi="l" rID="r38_l">
      <annotation gi="n">Bk.1.14</annotation>
   </start>
   <start off="546" ext="66" gi="phr" rID="r39_phr"/>
