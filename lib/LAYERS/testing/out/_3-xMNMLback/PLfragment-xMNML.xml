   <end off="421" ext="35" gi="l" rID="r28_l"/>
   <text off="421" ext="1" cf="r01_excerpt r03_s r30_phr">
</text>
   <start off="422" ext="48" gi="l" rID="r31_l">
      <annotation gi="n">Bk.1.11</annotation>
   </start>
   <text off="422" ext="18" cf="r01_excerpt r03_s r30_phr r31_l">Delight thee more,</text>
   <end off="440" ext="31" gi="phr" rID="r30_phr"/>
   <text off="440" ext="1" cf="r01_excerpt r03_s r31_l"> </text>
   <start off="441" ext="56" gi="phr" rID="r32_phr"/>
