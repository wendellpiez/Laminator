         ext="41"
         cf="r01_excerpt r03_s r37_np r41_phr r42_l r43_np">Things unattempted yet in prose or rhyme.</text>
   <end off="671" ext="670" gi="s" rID="r03_s"/>
   <end off="671" ext="58" gi="phr" rID="r41_phr"/>
   <end off="671" ext="41" gi="l" rID="r42_l"/>
