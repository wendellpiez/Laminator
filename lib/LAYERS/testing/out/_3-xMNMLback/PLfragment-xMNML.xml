   <end off="385" ext="42" gi="l" rID="r27_l"/>
   <text off="385" ext="1" cf="r01_excerpt r03_s r24_phr r26_np">
</text>
   <start off="386" ext="35" gi="l" rID="r28_l">
      <annotation gi="n">Bk.1.10</annotation>
   </start>
   <text off="386" ext="18" cf="r01_excerpt r03_s r24_phr r26_np r28_l">Rose out of Chaos:</text>
   <end off="404" ext="122" gi="phr" rID="r24_phr"/>
   <end off="404" ext="108" gi="np" id="4" rID="r26_np"/>
   <text off="404" ext="1" cf="r01_excerpt r03_s r28_l"> </text>
   <start off="405" ext="3" gi="phr" rID="r29_phr"/>
   <text off="405" ext="3" cf="r01_excerpt r03_s r28_l r29_phr">or,</text>
   <end off="408" ext="3" gi="phr" rID="r29_phr"/>
   <text off="408" ext="1" cf="r01_excerpt r03_s r28_l"> </text>
   <start off="409" ext="31" gi="phr" rID="r30_phr"/>
