   <end off="950" ext="42" gi="l" rID="r60_l"/>
   <text off="950" ext="1" cf="r01_excerpt r45_s r62_phr">
</text>
   <start off="951" ext="40" gi="l" rID="r63_l">
      <annotation gi="n">Bk.1.23</annotation>
   </start>
