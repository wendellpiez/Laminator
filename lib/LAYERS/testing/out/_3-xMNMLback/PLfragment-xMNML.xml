   <end off="588" ext="42" gi="l" rID="r38_l"/>
   <text off="588" ext="1" cf="r01_excerpt r03_s r37_np r39_phr">
</text>
   <start off="589" ext="40" gi="l" rID="r40_l">
      <annotation gi="n">Bk.1.15</annotation>
   </start>
