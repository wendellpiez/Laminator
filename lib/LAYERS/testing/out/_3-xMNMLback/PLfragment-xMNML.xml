   <end off="814" ext="50" gi="l" rID="r51_l"/>
   <text off="814" ext="1" cf="r01_excerpt r45_s r54_phr">
</text>
   <start off="815" ext="47" gi="l" rID="r55_l">
      <annotation gi="n">Bk.1.20</annotation>
   </start>
