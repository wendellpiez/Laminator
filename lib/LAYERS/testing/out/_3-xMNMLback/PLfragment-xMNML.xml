   </start>
   <text off="296"
         ext="13"
         cf="r01_excerpt r03_s r18_np r24_phr r25_l r26_np">That Shepherd</text>
   <end off="309" ext="88" gi="np" id="3" rID="r18_np"/>
   <text off="309" ext="33" cf="r01_excerpt r03_s r24_phr r25_l r26_np"> who first taught the chosen seed</text>
   <end off="342" ext="46" gi="l" rID="r25_l"/>
