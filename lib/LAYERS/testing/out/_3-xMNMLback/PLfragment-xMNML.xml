   <end off="763" ext="73" gi="np" id="8" rID="r47_np"/>
   <end off="763" ext="63" gi="phr" rID="r49_phr"/>
   <end off="763" ext="46" gi="l" rID="r50_l"/>
   <text off="763" ext="1" cf="r01_excerpt r45_s">
</text>
